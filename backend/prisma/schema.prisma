generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StudyLog {
  id        String   @id @default(cuid())
  userId    String
  phase     String
  person    String
  date      DateTime
  hours     Float
  topics    String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}